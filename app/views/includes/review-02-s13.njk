
<div style="width: 66%;float:left">
  <!--<h2 class="govuk-heading-l">Summary</h2>-->


  <!--<p>Key items from the application:</p>-->

  <!--<p style="font-size: 0.9em;"><i>Note: cribbed from p11 UR report "What are COs looking for when skimming
documents?" ...makes sense but naming of items may need checking. I like this as it gets to the point of collecting the docs in the first place, and can pick out missing info directly.</i></p>-->

  

  <form class="form" action="" method="post" >
      <style>
        .sumnumlist {
          display:inline-block;
          width:2em;
          font-weight: 600;
        }
        
      </style>

      {% set tenantType %}
      <div style="width:500px">
      <ul class="govuk-list" style="margin-bottom: 0;">
        <li><span class="sumnumlist">1.1</span> Challenging a rent increase in a section 13 notice</li>
        <li><span class="sumnumlist">1.2</span> Assured tenancy</li>
        <li><span class="sumnumlist">1.3</span> On or after 1 May 2026</li>
        <li><span class="sumnumlist">1.4</span> Not social housing, fee payable</li>
      </ul>
      </div>
      {% endset -%}

      {% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

      <!--<h3 class="govuk-heading-m">Section 13 notice</h3>-->

      {{ govukSummaryList({
        rows: [
          {
            key: {
              html: "Tenant name"
            },
            value: {
              text: globals.case_tenantname2
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              html: "New rent amount"
            },
            value: {
              text: "£1100 monthly"
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              html: "Date of rent increase"
            },
            value: {
              text: "Not provided - no Section 13"
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              html: "Landlord's name"
            },
            value: {
              text: globals.case_landlordname2
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              html: "Landlord's email"
            },
            value: {
              text: globals.case_landlordemail2
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              html: "Date signed by landlord"
            },
            value: {
              text: "Not provided - no Section 13"
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              text: "Document"
            },
            value: {
              html: "Not provided - no Section 13"
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          },
          {
            key: {
              text: "Reason for Section 13 not being provided"
            },
            value: {
              html: "Was not given it"
            },
            actions: {
              items: [
                {
                  href: "#",
                  text: ""
                }
              ]
            }
          }
        ]
      }) }}




    
        
        
        <div class="govuk-button-group">
          {{ govukButton({
            text: "Return to case",
            classes: "govuk-button--secondary",
            href: ""
          }) }}

       

          {{ govukButton({
            text: "Request missing information",
            href: ""
          }) }}
        </div>
      </form>






</div>

